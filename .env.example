# Copy this file to .env and fill in real values
WEATHER_API=your-openweathermap-key
GEMINI_API=your-gemini-key
FLIGHT_API=your-flight-api-key
MAPS_API=your-google-maps-key

# CORS: comma-separated allowed origins
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Set to true after rotating all API keys (they were exposed in git history)
KEYS_ROTATED=false
